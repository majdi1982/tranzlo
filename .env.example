# Appwrite
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://appwrite.tranzlo.net/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id
APPWRITE_API_KEY=your_api_key

# Mock toggle — set to "true" for local development without Appwrite
NEXT_PUBLIC_USE_MOCK_DATA=true

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=your_adsense_client_id

# Social Media (for auto-sharing blog posts)
# X/Twitter: https://developer.twitter.com/ -> Bearer Token (v2)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
# Facebook: https://developers.facebook.com/ -> Page Access Token
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
# LinkedIn: https://www.linkedin.com/developers/ -> Access Token
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# Veem Configuration
VEEM_MODE=sandbox
VEEM_CLIENT_ID=your_veem_client_id
VEEM_CLIENT_SECRET=your_veem_client_secret

